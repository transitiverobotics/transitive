          },
          "pluginVersion": "4.14.0",
          "queryType": "table",
          "rawSql": "SELECT\n  Timestamp,\n  JSONExtract(Payload, 'Float32') as value,\n  splitByChar('/', '${__user.login}') as userParts,\n  arrayMap(x -> decodeURLComponent(x), splitByChar('/', '${subtopic}')) as subTopicPrefix\nFROM\n  mqtt_history\nWHERE\n  TopicParts[1] = userParts[1] AND TopicParts[2] = userParts[2] AND\n  TopicParts[3] = userParts[3] AND TopicParts[4] = userParts[4] AND\n  (\n    Timestamp >= $__fromTime_ms\n    AND Timestamp <= $__toTime_ms\n  )\n  AND (arraySlice(TopicParts, 6, length(subTopicPrefix)) = subTopicPrefix)\n",
          "refId": "A"
        }
      ],
      "title": "",
      "transparent": true,
      "type": "timeseries"
